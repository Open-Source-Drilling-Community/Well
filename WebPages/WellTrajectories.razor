@page "/WellTrajectories"
@inject ILogger<WellTrajectories> logger
@inject ISnackbar Snackbar
@inject IWellAPIUtils Api
@using System.Net.Http.Json
@using System.Text.Json
@using WellModelShared = NORCE.Drilling.Well.ModelShared

<MudUnitAndReferenceChoiceTag HttpHost=@Api.HostNameUnitConversion
                              HttpBasePath=@Api.HostBasePathUnitConversion
                              HttpController="UnitSystem/"
                              UnitSystemName="@DataUtils.UnitAndReferenceParameters.UnitSystemName"
                              UnitSystemNameChanged="@DataUtils.UpdateUnitSystemName"
                              DepthReferenceName="@DataUtils.UnitAndReferenceParameters.DepthReferenceName"
                              DepthReferenceNameChanged="@DataUtils.UpdateDepthReferenceName"
                              GroundMudLineDepthReferenceSource="@DataUtils.UnitAndReferenceParameters.GroundMudLineDepthReferenceSource"
                              SeaWaterLevelDepthReferenceSource="@DataUtils.UnitAndReferenceParameters.SeaWaterLevelDepthReferenceSource">
    @if (fieldList == null || clusterList == null || wellList == null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <MudStack Spacing="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.h5">Well Trajectories</MudText>
                        <MudText Typo="Typo.body2">All trajectories for the selected well, shown in 3D and as a horizontal projection.</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="4" md="2">
                        <MudSelect Label="Field" T="Guid?" Value="@selectedFieldId" ValueChanged="OnFieldChanged" ShrinkLabel Clearable="true">
                            @foreach (WellModelShared.Field field in AvailableFields)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)field.MetaInfo.ID)">@field.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="4" md="2">
                        <MudSelect Label="Cluster" T="Guid?" Value="@selectedClusterId" ValueChanged="OnClusterChanged" ShrinkLabel Clearable="true" Disabled="@(selectedFieldId == null || AvailableClusters.Count == 0)">
                            @foreach (WellModelShared.Cluster cluster in AvailableClusters)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)cluster.MetaInfo.ID)">@cluster.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="4" md="3">
                        <MudSelect Label="Well" T="Guid?" Value="@selectedWellId" ValueChanged="OnWellChanged" ShrinkLabel Clearable="true" Disabled="@(selectedFieldId == null || AvailableWells.Count == 0)">
                            @foreach (WellModelShared.Well well in AvailableWells)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)well.MetaInfo.ID)">@well.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="1">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="ReloadSelectedWellAsync" Disabled="@(selectedWellId == null)">Reload</MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="4" md="2">
                        <MudSelect Label="Type" T="string" Value="@selectedTrajectoryTypeFilter" ValueChanged="OnTrajectoryFilterChanged" ShrinkLabel>
                            <MudSelectItem T="string" Value="@TrajectoryTypeFilterAll">All</MudSelectItem>
                            <MudSelectItem T="string" Value="@TrajectoryTypeFilterPlanned">Planned</MudSelectItem>
                            <MudSelectItem T="string" Value="@TrajectoryTypeFilterActual">Actual</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="4" md="2">
                        <MudCheckBox T="bool" Value="@definitiveTrajectoryOnly" ValueChanged="OnDefinitiveTrajectoryFilterChanged" Label="Definitive only" />
                    </MudItem>
                </MudGrid>
                <MudDivider Class="my-3" />
                <MudGrid>
                    <MudItem xs="12" sm="4" md="3">
                        <MudNumericField @bind-Value="ellipseConfidenceFactor" Label="Confidence factor" Min="0.0" Max="1.0" Step="0.01" ShrinkLabel />
                    </MudItem>
                    <MudItem xs="12" sm="4" md="3">
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" OnClick="CalculateUncertaintyEllipsesAsync" Disabled="@(trajectoryList.Count == 0 || isLoadingTrajectories || isCalculatingEllipses)">Calculate Ellipses</MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="4" md="3">
                        <MudButton Variant="Variant.Text" Color="Color.Secondary" FullWidth="true" OnClick="ClearUncertaintyEllipses" Disabled="@(ellipseResultsByTrajectory.Count == 0 || isCalculatingEllipses)">Clear Ellipses</MudButton>
                    </MudItem>
                    @if (isCalculatingEllipses)
                    {
                        <MudItem xs="12" md="3">
                            <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="mt-4" />
                        </MudItem>
                    }
                </MudGrid>            </MudPaper>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Dense="true">@errorMessage</MudAlert>
            }
            else if (isLoadingTrajectories)
            {
                <MudAlert Severity="Severity.Info" Dense="true">Loading trajectories for the selected well.</MudAlert>
            }
            else if (selectedFieldId == null)
            {
                <MudAlert Severity="Severity.Info" Dense="true">Select a field to display its wells.</MudAlert>
            }
            else if (AvailableWells.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">No wells were found for the selected filters.</MudAlert>
            }
            else if (selectedWellId == null)
            {
                <MudAlert Severity="Severity.Info" Dense="true">Select a well to display its trajectories.</MudAlert>
            }
            else if (trajectoryList.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">No trajectories were found for the selected well.</MudAlert>
            }
            else
            {
                <MudGrid>
                    <MudItem xs="12" xl="6">
                        <MudPaper Class="pa-4" Elevation="2">
                            <MudText Typo="Typo.h6">3D View</MudText>
                            <Scatter3DPlot XUnit="PositionDrilling"
                                           YUnit="PositionDrilling"
                                           ZUnit="DepthDrilling"
                                           NameList="@Plot3DNames"
                                           ModeFlagList="@Plot3DModeFlags"
                                           ColorList="@Plot3DColors"
                                           XValuesList="@Plot3DEastValuesList"
                                           YValuesList="@Plot3DNorthValuesList"
                                           ZValuesList="@Plot3DTvdValuesList"
                                           XAxisTitle="Easting"
                                           YAxisTitle="Northing"
                                           ZAxisTitle="TVD"
                                           PlotTitle="Well trajectories"
                                           PlotHeight="600"
                                           ZAxisReversed="true"
                                           XDrillingSignalReference="@DrillingSignalReferenceType.Position"
                                           YDrillingSignalReference="@DrillingSignalReferenceType.Position"
                                           ZDrillingSignalReference="@DrillingSignalReferenceType.Depth"
                                           PositionDirectionX="@PositionDirectionType.East"
                                           PositionDirectionY="@PositionDirectionType.North"
                                           ShowLegends="@Plot3DShowLegends" />
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" xl="6">
                        <MudPaper Class="pa-4" Elevation="2">
                            <MudText Typo="Typo.h6">Horizontal Projection</MudText>
                            <ScatterPlot XUnit="PositionDrilling"
                                         YUnit="PositionDrilling"
                                         NameList="@PlotHorizontalNames"
                                         ModeFlagList="@PlotHorizontalModeFlags"
                                         ColorList="@PlotHorizontalColors"
                                         XValuesList="@PlotHorizontalEastValuesList"
                                         YValuesList="@PlotHorizontalNorthValuesList"
                                         XAxisTitle="Easting"
                                         YAxisTitle="Northing"
                                         PlotTitle="Horizontal projection"
                                         PlotHeight="600"
                                         AspectRatio="1"
                                         XDrillingSignalReference="@DrillingSignalReferenceType.Position"
                                         YDrillingSignalReference="@DrillingSignalReferenceType.Position"
                                         PositionDirectionX="@PositionDirectionType.East"
                                         PositionDirectionY="@PositionDirectionType.North"
                                           ShowLegends="@PlotHorizontalShowLegends" />
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6">Legend</MudText>
                    <MudGrid>
                        @foreach (var trace in plotTraces.Where(trace => trace.ShowLegend))
                        {
                            <MudItem xs="12" sm="6" md="4" lg="3">
                                <div style="display:flex;align-items:center;gap:12px;">
                                    <span style="@($"width:18px;height:18px;border-radius:50%;display:inline-block;background:{trace.Color};")"></span>
                                    <MudText Typo="Typo.body2">@trace.Name</MudText>
                                </div>
                            </MudItem>
                        }
                    </MudGrid>
                </MudPaper>
            }
        </MudStack>
    }
</MudUnitAndReferenceChoiceTag>

@code {
    private List<WellModelShared.Field>? fieldList;
    private List<WellModelShared.Cluster>? clusterList;
    private List<WellModelShared.Well>? wellList;
    private List<WellModelShared.TrajectoryLight> trajectoryLightList = [];
    private List<WellModelShared.Trajectory> trajectoryList = [];
    private Guid? selectedFieldId;
    private Guid? selectedClusterId;
    private Guid? selectedWellId;
    private string? errorMessage;
    private bool isLoadingTrajectories;
    private const string TrajectoryTypeFilterAll = "All";
    private const string TrajectoryTypeFilterPlanned = "Planned";
    private const string TrajectoryTypeFilterActual = "Actual";
    private string selectedTrajectoryTypeFilter = TrajectoryTypeFilterAll;
    private bool definitiveTrajectoryOnly;
    private bool isCalculatingEllipses;
    private double ellipseConfidenceFactor = 0.95;
    private List<PlotTrace> plotTraces = [];
    private Dictionary<Guid, List<WellModelShared.SurveyStationEllipseResult>> ellipseResultsByTrajectory = [];

    private List<string> PlotNames => plotTraces.Select(trace => trace.Name).ToList();
    private List<int> PlotModeFlags => plotTraces.Select(trace => trace.ModeFlag).ToList();
    private List<string> PlotColors => plotTraces.Select(trace => trace.Color).ToList();
    private List<bool> PlotShowLegends => plotTraces.Select(trace => trace.ShowLegend).ToList();
    private List<List<object>> NorthValuesList => plotTraces.Select(trace => trace.NorthValues).ToList();
    private List<List<object>> EastValuesList => plotTraces.Select(trace => trace.EastValues).ToList();
    private List<List<object>> TvdValuesList => plotTraces.Select(trace => trace.TvdValues).ToList();
    private List<string> Plot3DNames => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.Name).ToList();
    private List<int> Plot3DModeFlags => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.ModeFlag).ToList();
    private List<string> Plot3DColors => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.Color).ToList();
    private List<bool> Plot3DShowLegends => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.ShowLegend).ToList();
    private List<List<object>> Plot3DNorthValuesList => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.NorthValues).ToList();
    private List<List<object>> Plot3DEastValuesList => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.EastValues).ToList();
    private List<List<object>> Plot3DTvdValuesList => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.TvdValues).ToList();
    private List<string> PlotHorizontalNames => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.Name).ToList();
    private List<int> PlotHorizontalModeFlags => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.ModeFlag).ToList();
    private List<string> PlotHorizontalColors => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.Color).ToList();
    private List<bool> PlotHorizontalShowLegends => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.ShowLegend).ToList();
    private List<List<object>> PlotHorizontalNorthValuesList => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.NorthValues).ToList();
    private List<List<object>> PlotHorizontalEastValuesList => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.EastValues).ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            logger.LogInformation("Trying to load list of Fields, Clusters and Wells");
            Task<ICollection<WellModelShared.Field>> fieldTask = Api.ClientField.GetAllFieldAsync();
            Task<ICollection<WellModelShared.Cluster>> clusterTask = Api.ClientCluster.GetAllClusterAsync();
            Task<ICollection<WellModelShared.Well>> wellTask = Api.ClientWell.GetAllWellAsync();

            await Task.WhenAll(fieldTask, clusterTask, wellTask);

            fieldList = fieldTask.Result.Where(field => field?.MetaInfo != null).OrderBy(field => field.Name).ToList();
            clusterList = clusterTask.Result.Where(cluster => cluster?.MetaInfo != null).OrderBy(cluster => cluster.Name).ToList();
            wellList = wellTask.Result.Where(well => well?.MetaInfo != null).OrderBy(well => well.Name).ToList();
        }
        catch (ApiException ex)
        {
            logger.LogError(ex, "Problem while loading fields, clusters and wells");
            errorMessage = "Unable to load fields, clusters and wells.";
            Snackbar.Add(errorMessage, Severity.Error);
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Unexpected problem while loading fields, clusters and wells");
            errorMessage = "Unable to load fields, clusters and wells.";
            Snackbar.Add(errorMessage, Severity.Error);
        }

        await InvokeAsync(StateHasChanged);
    }

    private List<WellModelShared.Field> AvailableFields =>
        fieldList?.Where(field => field?.MetaInfo != null).OrderBy(field => field.Name).ToList() ?? [];

    private List<WellModelShared.Cluster> AvailableClusters =>
        clusterList?
            .Where(cluster => cluster?.MetaInfo != null && cluster.FieldID == selectedFieldId && !cluster.IsSingleWell)
            .OrderBy(cluster => cluster.Name)
            .ToList() ?? [];

    private List<WellModelShared.Well> AvailableWells =>
        wellList?
            .Where(well => MatchesSelectedField(well) && MatchesSelectedCluster(well))
            .OrderBy(well => well.Name)
            .ToList() ?? [];

    private bool MatchesSelectedField(WellModelShared.Well? well)
    {
        if (selectedFieldId == null || well?.ClusterID == null || clusterList == null)
        {
            return false;
        }

        WellModelShared.Cluster? cluster = clusterList.FirstOrDefault(c => c?.MetaInfo?.ID == well.ClusterID);
        return cluster?.FieldID == selectedFieldId;
    }

    private bool MatchesSelectedCluster(WellModelShared.Well? well)
    {
        if (selectedClusterId == null)
        {
            return true;
        }

        return well?.ClusterID == selectedClusterId;
    }

    private async Task OnFieldChanged(Guid? fieldId)
    {
        selectedFieldId = fieldId;
        selectedClusterId = null;
        selectedWellId = null;
        trajectoryLightList.Clear();
        trajectoryList.Clear();
        ClearPlots();
        errorMessage = null;
        DataUtils.ApplyWellReferenceValues(null, clusterList ?? []);
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnClusterChanged(Guid? clusterId)
    {
        selectedClusterId = clusterId;
        selectedWellId = null;
        trajectoryLightList.Clear();
        trajectoryList.Clear();
        ClearPlots();
        errorMessage = null;
        DataUtils.ApplyWellReferenceValues(null, clusterList ?? []);
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnWellChanged(Guid? wellId)
    {
        selectedWellId = wellId;
        if (selectedWellId is Guid selected && selectedFieldId is Guid fieldId)
        {
            ApplySelectedWellReferenceValues(selected);
            await LoadTrajectoriesAsync(fieldId, selectedClusterId, selected);
        }
        else
        {
            trajectoryLightList.Clear();
            trajectoryList.Clear();
            ClearPlots();
            errorMessage = null;
            DataUtils.ApplyWellReferenceValues(null, clusterList ?? []);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ReloadSelectedWellAsync()
    {
        if (selectedFieldId is Guid fieldId && selectedWellId is Guid wellId)
        {
            ApplySelectedWellReferenceValues(wellId);
            await LoadTrajectoriesAsync(fieldId, selectedClusterId, wellId);
        }
    }

    private void ApplySelectedWellReferenceValues(Guid wellId)
    {
        WellModelShared.Well? selectedWell = wellList?.FirstOrDefault(well => well.MetaInfo?.ID == wellId);
        DataUtils.ApplyWellReferenceValues(selectedWell, clusterList ?? []);
    }


    private async Task OnTrajectoryFilterChanged(string value)
    {
        selectedTrajectoryTypeFilter = string.IsNullOrWhiteSpace(value) ? TrajectoryTypeFilterAll : value;
        await ReloadCurrentSelectionAsync();
    }

    private async Task OnDefinitiveTrajectoryFilterChanged(bool value)
    {
        definitiveTrajectoryOnly = value;
        await ReloadCurrentSelectionAsync();
    }

    private bool MatchesTrajectoryFilters(WellModelShared.TrajectoryLight trajectory)
    {
        bool typeMatches = selectedTrajectoryTypeFilter == TrajectoryTypeFilterAll ||
            string.Equals(trajectory.TrajectoryType.ToString(), selectedTrajectoryTypeFilter, StringComparison.OrdinalIgnoreCase);
        bool definitiveMatches = !definitiveTrajectoryOnly || trajectory.IsDefinitive;
        return typeMatches && definitiveMatches;
    }

    private async Task ReloadCurrentSelectionAsync()
    {
        if (selectedFieldId is Guid fieldId && selectedWellId is Guid wellId) { ApplySelectedWellReferenceValues(wellId); await LoadTrajectoriesAsync(fieldId, selectedClusterId, wellId); }
    }

    private async Task LoadTrajectoriesAsync(Guid fieldId, Guid? clusterId, Guid wellId)
    {
        try
        {
            errorMessage = null;
            isLoadingTrajectories = true;
            trajectoryLightList.Clear();
            trajectoryList.Clear();
            ClearPlots();
            await InvokeAsync(StateHasChanged);

            logger.LogInformation("Loading trajectory light data for field {FieldId}, cluster {ClusterId} and well {WellId}", fieldId, clusterId, wellId);
            trajectoryLightList = (await Api.ClientTrajectory.GetAllTrajectoryLightAsync(fieldId: fieldId, clusterId: clusterId, wellId: wellId))
                .Where(trajectory => trajectory?.MetaInfo != null && trajectory.MetaInfo.ID != Guid.Empty)
                .Where(MatchesTrajectoryFilters)
                .OrderBy(trajectory => trajectory.Name)
                .ToList();

            List<Task<WellModelShared.Trajectory>> detailTasks = trajectoryLightList
                .Select(light => LoadTrajectoryWithSurveyStationsAsync(light.MetaInfo.ID))
                .ToList();

            trajectoryList = (await Task.WhenAll(detailTasks))
                .Where(trajectory => trajectory != null)
                .OrderBy(trajectory => trajectory.Name)
                .ToList();

            UpdatePlots();
        }
        catch (ApiException ex)
        {
            logger.LogError(ex, "Problem while loading trajectories for well {WellId}", wellId);
            errorMessage = "Unable to load trajectories for the selected well.";
            Snackbar.Add(errorMessage, Severity.Error);
            trajectoryLightList.Clear();
            trajectoryList.Clear();
            ClearPlots();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Unexpected problem while loading trajectories for well {WellId}", wellId);
            errorMessage = "Unable to load trajectories for the selected well.";
            Snackbar.Add(errorMessage, Severity.Error);
            trajectoryLightList.Clear();
            trajectoryList.Clear();
            ClearPlots();
        }
        finally
        {
            isLoadingTrajectories = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task<WellModelShared.Trajectory> LoadTrajectoryWithSurveyStationsAsync(Guid trajectoryId)
    {
        WellModelShared.Trajectory trajectory = await Api.ClientTrajectory.GetTrajectoryByIdAsync(trajectoryId);
        int chunkCount = await Api.HttpClientTrajectory.GetFromJsonAsync<int>($"Trajectory/{trajectoryId}/SurveyStations/ChunkCount");
        if (chunkCount <= 0)
        {
            trajectory.SurveyStationList ??= [];
            return trajectory;
        }

        List<WellModelShared.SurveyStation> stations = [];
        for (int chunkIndex = 0; chunkIndex < chunkCount; chunkIndex++)
        {
            WellModelShared.SurveyStationChunk? chunk = await Api.HttpClientTrajectory.GetFromJsonAsync<WellModelShared.SurveyStationChunk>($"Trajectory/{trajectoryId}/SurveyStations/Chunks/{chunkIndex}");
            if (chunk?.SurveyStationList is { Count: > 0 } chunkStations)
            {
                stations.AddRange(chunkStations);
            }
        }

        trajectory.SurveyStationList = stations;
        return trajectory;
    }

    private void UpdatePlots()
    {
        int colorIndex = 0;
        List<PlotTrace> nextPlotTraces = [];

        foreach (WellModelShared.Trajectory trajectory in trajectoryList)
        {
            if (trajectory?.SurveyStationList == null || trajectory.SurveyStationList.Count == 0)
            {
                continue;
            }

            List<object> northValues = [];
            List<object> eastValues = [];
            List<object> tvdValues = [];

            foreach (WellModelShared.SurveyStation station in trajectory.SurveyStationList)
            {
                AppendPoint(station, northValues, eastValues, tvdValues);
            }

            if (northValues.Count < 2 || northValues.Count != eastValues.Count || northValues.Count != tvdValues.Count)
            {
                continue;
            }

            nextPlotTraces.Add(new PlotTrace(
                string.IsNullOrWhiteSpace(trajectory.Name) ? "trajectory" : trajectory.Name,
                1,
                Colors[colorIndex % Colors.Length],
                true,
                northValues,
                eastValues,
                tvdValues));
            colorIndex++;
        }

        AddEllipseTracesForLoadedTrajectories(nextPlotTraces);
        plotTraces = nextPlotTraces;
    }


    private async Task CalculateUncertaintyEllipsesAsync()
    {
        if (trajectoryList.Count == 0)
        {
            return;
        }

        try
        {
            isCalculatingEllipses = true;
            ellipseResultsByTrajectory.Clear();
            await InvokeAsync(StateHasChanged);

            foreach (WellModelShared.Trajectory trajectory in trajectoryList)
            {
                if (trajectory.MetaInfo?.ID is not Guid trajectoryId ||
                    trajectory.SurveyStationList is not { Count: > 0 } surveyStations)
                {
                    continue;
                }

                WellModelShared.SurveyStationEllipseCalculation order = new()
                {
                    MetaInfo = new WellModelShared.MetaInfo { ID = Guid.NewGuid() },
                    Name = $"{trajectory.Name} uncertainty ellipses",
                    Description = string.Empty,
                    CreationDate = DateTimeOffset.UtcNow,
                    LastModificationDate = DateTimeOffset.UtcNow,
                    ConfidenceFactor = ellipseConfidenceFactor,
                    SurveyStationList = surveyStations
                };

                HttpResponseMessage response = await Api.HttpClientTrajectory.PostAsJsonAsync("SurveyStationEllipseCalculation", order);
                response.EnsureSuccessStatusCode();
                WellModelShared.SurveyStationEllipseCalculation? result = await response.Content.ReadFromJsonAsync<WellModelShared.SurveyStationEllipseCalculation>();
                if (result?.SurveyStationEllipseResultList is { Count: > 0 } ellipseResults)
                {
                    ellipseResultsByTrajectory[trajectoryId] = ellipseResults.ToList();
                }
            }

            UpdatePlots();
            if (ellipseResultsByTrajectory.Count == 0)
            {
                Snackbar.Add("No uncertainty ellipses could be calculated.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Problem while calculating uncertainty ellipses");
            Snackbar.Add("Problem while calculating uncertainty ellipses: " + ex.Message, Severity.Error);
        }
        finally
        {
            isCalculatingEllipses = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private void ClearUncertaintyEllipses()
    {
        ellipseResultsByTrajectory.Clear();
        UpdatePlots();
    }

    private void AddEllipseTracesForLoadedTrajectories(List<PlotTrace> traces)
    {
        int colorIndex = 0;
        foreach (WellModelShared.Trajectory trajectory in trajectoryList)
        {
            if (trajectory?.SurveyStationList == null || trajectory.SurveyStationList.Count == 0)
            {
                continue;
            }

            List<object> northValues = [];
            List<object> eastValues = [];
            List<object> tvdValues = [];
            foreach (WellModelShared.SurveyStation station in trajectory.SurveyStationList)
            {
                AppendPoint(station, northValues, eastValues, tvdValues);
            }

            if (northValues.Count >= 2 && northValues.Count == eastValues.Count && northValues.Count == tvdValues.Count)
            {
                if (trajectory.MetaInfo?.ID is Guid trajectoryId &&
                    ellipseResultsByTrajectory.TryGetValue(trajectoryId, out var ellipseResults))
                {
                    AddEllipseTraces(traces, trajectory.SurveyStationList, ellipseResults, Colors[colorIndex % Colors.Length], trajectory.Name);
                }
                colorIndex++;
            }
        }
    }

    private static void AddEllipseTraces(
        List<PlotTrace> traces,
        ICollection<WellModelShared.SurveyStation> surveyStations,
        IReadOnlyList<WellModelShared.SurveyStationEllipseResult> ellipseResults,
        string color,
        string? trajectoryName)
    {
        bool horizontalLegendShown = false;
        bool perpendicularLegendShown = false;
        foreach ((WellModelShared.SurveyStation station, WellModelShared.SurveyStationEllipseResult result) in SelectEvenlySpacedEllipses(surveyStations, ellipseResults))
        {
            if (BuildHorizontalEllipseTrace(station, result.HorizontalEllipse, color, !horizontalLegendShown, trajectoryName) is { } horizontalTrace)
            {
                traces.Add(horizontalTrace);
                horizontalLegendShown = true;
            }
            if (BuildPerpendicularEllipseTrace(station, result.PerpendicularEllipse, color, !perpendicularLegendShown, trajectoryName) is { } perpendicularTrace)
            {
                traces.Add(perpendicularTrace);
                perpendicularLegendShown = true;
            }
        }
    }

    private static IReadOnlyList<(WellModelShared.SurveyStation Station, WellModelShared.SurveyStationEllipseResult Result)> SelectEvenlySpacedEllipses(
        ICollection<WellModelShared.SurveyStation> surveyStations,
        IReadOnlyList<WellModelShared.SurveyStationEllipseResult> ellipseResults)
    {
        List<(WellModelShared.SurveyStation Station, WellModelShared.SurveyStationEllipseResult Result)> candidates = [];
        foreach (WellModelShared.SurveyStationEllipseResult result in ellipseResults)
        {
            WellModelShared.SurveyStation? station = FindStation(surveyStations, result.MD);
            if (station != null)
            {
                candidates.Add((station, result));
            }
        }

        if (candidates.Count <= MaxDisplayedUncertaintyEllipses)
        {
            return candidates;
        }

        List<(WellModelShared.SurveyStation Station, WellModelShared.SurveyStationEllipseResult Result)> ordered = candidates
            .OrderBy(candidate => candidate.Result.MD ?? candidate.Station.MD ?? candidate.Station.Abscissa ?? double.MaxValue)
            .ToList();
        HashSet<int> selectedIndexes = [];
        for (int sampleIndex = 0; sampleIndex < MaxDisplayedUncertaintyEllipses; sampleIndex++)
        {
            int sourceIndex = (int)Math.Round(sampleIndex * (ordered.Count - 1.0) / (MaxDisplayedUncertaintyEllipses - 1.0));
            selectedIndexes.Add(Math.Clamp(sourceIndex, 0, ordered.Count - 1));
        }
        selectedIndexes.Add(ordered.Count - 1);
        return selectedIndexes.Order().Select(index => ordered[index]).ToList();
    }

    private static WellModelShared.SurveyStation? FindStation(ICollection<WellModelShared.SurveyStation> surveyStations, double? md)
    {
        if (md is not { } definedMd)
        {
            return null;
        }

        return surveyStations
            .Where(station => station != null && (station.MD ?? station.Abscissa) is { })
            .OrderBy(station => Math.Abs(((station.MD ?? station.Abscissa) ?? double.MaxValue) - definedMd))
            .FirstOrDefault();
    }

    private static PlotTrace? BuildHorizontalEllipseTrace(WellModelShared.SurveyStation station, WellModelShared.SurveyStationEllipse? ellipse, string color, bool showLegend, string? trajectoryName)
    {
        if (ellipse?.SemiMajorAxis is not double semiMajor ||
            ellipse.SemiMinorAxis is not double semiMinor ||
            ellipse.OrientationAngle is not double angle ||
            station.X is not double centerNorth ||
            station.Y is not double centerEast)
        {
            return null;
        }

        List<object> northValues = [];
        List<object> eastValues = [];
        List<object> tvdValues = [];
        double centerTvd = station.TVD ?? station.Z ?? 0.0;
        for (int i = 0; i <= EllipsePointCount; i++)
        {
            double phi = 2.0 * Math.PI * i / EllipsePointCount;
            double major = semiMajor * Math.Cos(phi);
            double minor = semiMinor * Math.Sin(phi);
            double northOffset = major * Math.Cos(angle) - minor * Math.Sin(angle);
            double eastOffset = major * Math.Sin(angle) + minor * Math.Cos(angle);
            northValues.Add(centerNorth + northOffset);
            eastValues.Add(centerEast + eastOffset);
            tvdValues.Add(centerTvd);
        }

        return new PlotTrace($"{trajectoryName ?? "trajectory"} horizontal ellipses", 1, color, showLegend, northValues, eastValues, tvdValues, false, true);
    }

    private static PlotTrace? BuildPerpendicularEllipseTrace(WellModelShared.SurveyStation station, WellModelShared.SurveyStationEllipse? ellipse, string color, bool showLegend, string? trajectoryName)
    {
        if (ellipse?.SemiMajorAxis is not double semiMajor ||
            ellipse.SemiMinorAxis is not double semiMinor ||
            ellipse.OrientationAngle is not double angle ||
            station.Inclination is not double inclination ||
            station.Azimuth is not double azimuth ||
            station.X is not double centerNorth ||
            station.Y is not double centerEast)
        {
            return null;
        }

        double centerTvd = station.TVD ?? station.Z ?? 0.0;
        double cosA = Math.Cos(azimuth);
        double sinA = Math.Sin(azimuth);
        double cosI = Math.Cos(inclination);
        double sinI = Math.Sin(inclination);
        double cosO = Math.Cos(angle);
        double sinO = Math.Sin(angle);
        List<object> northValues = [];
        List<object> eastValues = [];
        List<object> tvdValues = [];
        for (int i = 0; i <= EllipsePointCount; i++)
        {
            double phi = 2.0 * Math.PI * i / EllipsePointCount;
            double localX0 = semiMajor * Math.Cos(phi);
            double localY0 = semiMinor * Math.Sin(phi);
            double localX = localX0 * cosO - localY0 * sinO;
            double localY = localX0 * sinO + localY0 * cosO;
            northValues.Add(centerNorth + cosA * cosI * localX - sinA * localY);
            eastValues.Add(centerEast + sinA * cosI * localX + cosA * localY);
            tvdValues.Add(centerTvd - sinI * localX);
        }

        return new PlotTrace($"{trajectoryName ?? "trajectory"} perpendicular ellipses", 1, color, showLegend, northValues, eastValues, tvdValues, true, false);
    }

    private static void AppendPoint(WellModelShared.SurveyStation? point, List<object> northValues, List<object> eastValues, List<object> tvdValues)
    {
        if (point?.X is not { } north || point.Y is not { } east)
        {
            return;
        }

        double tvd = point.TVD ?? point.Z ?? 0.0;
        AppendPointValues(north, east, tvd, northValues, eastValues, tvdValues);
    }

    private static void AppendPointValues(double north, double east, double tvd, List<object> northValues, List<object> eastValues, List<object> tvdValues)
    {
        if (northValues.Count > 0 &&
            eastValues.Count == northValues.Count &&
            tvdValues.Count == northValues.Count &&
            TryGetLastDouble(northValues, out double lastNorth) &&
            TryGetLastDouble(eastValues, out double lastEast) &&
            TryGetLastDouble(tvdValues, out double lastTvd) &&
            AreClose(lastNorth, north) &&
            AreClose(lastEast, east) &&
            AreClose(lastTvd, tvd))
        {
            return;
        }

        northValues.Add(north);
        eastValues.Add(east);
        tvdValues.Add(tvd);
    }

    private static bool TryGetLastDouble(List<object> values, out double value)
    {
        value = default;
        if (values.Count == 0)
        {
            return false;
        }

        object last = values[^1];
        return last switch
        {
            double d => (value = d) == d,
            float f => (value = f) == f,
            decimal m => (value = (double)m) == (double)m,
            int i => (value = i) == i,
            long l => (value = l) == l,
            _ => false
        };
    }

    private static bool AreClose(double left, double right)
    {
        return Math.Abs(left - right) <= 1e-6;
    }

