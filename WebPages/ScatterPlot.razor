@implements IUnitAwareComponent

<PlotlyChart @bind-Config="config" @bind-Layout="layout" @bind-Data="data" @ref="chart" Id="@GetID()"/>

@code {
    [CascadingParameter]
    private MudUnitAndReferenceChoiceTag? Parent { get; set; }

    [Parameter]
    public string ID { get; set; } = "default";

    [Parameter]
    public String? XUnit { get; set; }

    [Parameter]
    public String? YUnit { get; set; }

    [Parameter]
    public List<string>? NameList { get; set; }

    [Parameter]
    public List<int>? ModeFlagList { get; set; }

    [Parameter]
    public List<string>? ColorList { get; set; }

    [Parameter]
    public List<bool>? ShowLegends { get; set; }

    [Parameter]
    public List<bool>? ShowMarkers { get; set; }

    [Parameter]
    public List<List<object>>? XValuesList { get; set; }

    [Parameter]
    public List<List<object>>? YValuesList { get; set; }

    [Parameter]
    public int PlotHeight { get; set; }

    [Parameter]
    public int PlotWidth { get; set; }

    [Parameter]
    public string? PlotTitle { get; set; }

    [Parameter]
    public string? XAxisTitle { get; set; }

    [Parameter]
    public string? YAxisTitle { get; set; }

    [Parameter]
    public bool XAxisReversed { get; set; }

    [Parameter]
    public bool YAxisReversed { get; set; }

    [Parameter]
    public decimal? AspectRatio { get; set; } = null;

    [Parameter]
    public DrillingSignalReferenceType DrillingSignalReference { get; set; } = DrillingSignalReferenceType.Independent;

    [Parameter]
    public DrillingSignalReferenceType XDrillingSignalReference { get; set; } = DrillingSignalReferenceType.Independent;

    [Parameter]
    public DrillingSignalReferenceType YDrillingSignalReference { get; set; } = DrillingSignalReferenceType.Independent;

    [Parameter]
    public PositionDirectionType PositionDirectionX { get; set; } = PositionDirectionType.Independent;

    [Parameter]
    public PositionDirectionType PositionDirectionY { get; set; } = PositionDirectionType.Independent;

    private string GetID()
    {
        return ID;
    }

    private PlotlyChart? chart;
    private Config config = new Config() { Responsive = true };
    private Layout layout = new Layout
        {
            Title = new Plotly.Blazor.LayoutLib.Title { Text = "" },
            XAxis = new List<XAxis>
{
            new XAxis
            {
                Title = new Plotly.Blazor.LayoutLib.XAxisLib.Title { Text = "" }
            }
        },
            YAxis = new List<YAxis>
{
            new YAxis
            {
                Title = new Plotly.Blazor.LayoutLib.YAxisLib.Title { Text = "" },
            }
        }
        };

    // Using of the interface IList is important for the event callback!
    private IList<ITrace> data = new List<ITrace>();
    private int _plotVersion = 0;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        if (Parent == null)
            throw new ArgumentNullException(nameof(Parent), "ScatterPlot must exist within a UnitAndReferenceChoiceTag");
        Parent.Add(this);
        ManageUnits();
    }

    public void ManageUnits()
    {
        Plot();
    }

    public void Plot()
    {
        _ = PlotAsync();
    }

    private DrillingSignalReferenceType GetXDrillingSignalReference() =>
        XDrillingSignalReference != DrillingSignalReferenceType.Independent ? XDrillingSignalReference : DrillingSignalReference;

    private DrillingSignalReferenceType GetYDrillingSignalReference() =>
        YDrillingSignalReference != DrillingSignalReferenceType.Independent ? YDrillingSignalReference : DrillingSignalReference;

    private string GetAxisUnitLabel(string unit)
    {
        if (Parent == null)
            return string.Empty;

        return Parent.GetUnitLabel(unit);
    }

    private string GetAxisTitle(string axisTitle, string unit, DrillingSignalReferenceType drillingSignalReference)
    {
        if (Parent == null)
            return axisTitle;

        if (drillingSignalReference == DrillingSignalReferenceType.Depth)
        {
            var depthUnitLabel = Parent.GetDepthUnitLabel(unit);
            return string.IsNullOrWhiteSpace(depthUnitLabel) ? axisTitle : depthUnitLabel;
        }

        var unitLabel = GetAxisUnitLabel(unit);
        return string.IsNullOrWhiteSpace(unitLabel) ? axisTitle : axisTitle + " (" + unitLabel + ")";
    }

    private async Task PlotAsync()
    {
        if (Parent != null && XValuesList != null && XValuesList.Any() && YValuesList != null &&
            XValuesList.Count == YValuesList.Count && chart != null && XUnit != null && YUnit != null)
        {
            var plotVersion = Interlocked.Increment(ref _plotVersion);
            var xDrillingSignalReference = GetXDrillingSignalReference();
            var yDrillingSignalReference = GetYDrillingSignalReference();
            //Remove existing traces
            await chart!.Clear();

            for (int i = 0; i < XValuesList.Count; i++)
            {
                if (plotVersion != _plotVersion)
                {
                    return;
                }

                List<object> XValuesInUserUnit = new List<object>();
                List<object> YValuesInUserUnit = new List<object>();
                foreach (object x in XValuesList[i])
                {
                    double? X = null;
                    if (x is double?)
                    {
                        switch (xDrillingSignalReference)
                        {
                            case DrillingSignalReferenceType.Pressure:
                                X = Parent.FromAbsolutePressureSI((double?)x, XUnit!);
                                break;
                            case DrillingSignalReferenceType.Azimuth:
                                X = Parent.FromTrueNorthAzimuthSI((double?)x, XUnit!);
                                break;
                            case DrillingSignalReferenceType.Depth:
                                X = Parent.FromWGS84DepthSI((double?)x, XUnit!);
                                break;
                            case DrillingSignalReferenceType.Position:
                                X = Parent.FromWGS84PositionSI((double?)x, XUnit!, PositionDirectionX);
                                break;
                            default:
                                X = Parent.FromSI((double?)x, XUnit);
                                break;
                        }
                    }
                    if (x is int?)
                        X = Parent.FromSI((int?)x, XUnit);
                    if (X != null)
                        XValuesInUserUnit.Add((double)X);
                }
                foreach (object y in YValuesList[i])
                {
                    double? Y = null;
                    if (y is double?)
                    {
                        switch (yDrillingSignalReference)
                        {
                            case DrillingSignalReferenceType.Pressure:
                                Y = Parent.FromAbsolutePressureSI((double?)y, YUnit!);
                                break;
                            case DrillingSignalReferenceType.Azimuth:
                                Y = Parent.FromTrueNorthAzimuthSI((double?)y, YUnit!);
                                break;
                            case DrillingSignalReferenceType.Depth:
                                Y = Parent.FromWGS84DepthSI((double?)y, YUnit!);
                                break;
                            case DrillingSignalReferenceType.Position:
                                Y = Parent.FromWGS84PositionSI((double?)y, YUnit!, PositionDirectionY);
                                break;
                            default:
                                Y = Parent.FromSI((double?)y, YUnit);
                                break;
                        }
                    }
                    if (y is int?)
                        Y = Parent.FromSI((int?)y, YUnit);
                    if (Y != null)
                        YValuesInUserUnit.Add((double)Y);
                }
                //Add converted input values to a trace
                if (XValuesInUserUnit.Count == YValuesInUserUnit.Count)
                {
                    string name = (NameList != null && i < NameList.Count) ? NameList[i] : "";
                    Plotly.Blazor.Traces.ScatterLib.ModeFlag modeFlag = (ModeFlagList != null && i < ModeFlagList.Count) ? (Plotly.Blazor.Traces.ScatterLib.ModeFlag)ModeFlagList[i] : Plotly.Blazor.Traces.ScatterLib.ModeFlag.Lines;
                    Plotly.Blazor.Traces.ScatterLib.Marker marker;
                    if (ColorList != null && i < ColorList.Count)
                    {
                        marker = new Marker { Color = ColorList[i] };
                    }
                    else
                    {
                        marker = new Marker { AutoColorScale = true };
                    }
                    bool showLegend = (ShowLegends != null && i < ShowLegends.Count) ? ShowLegends[i] : true;
                    bool showMarker = (ShowMarkers != null && i < ShowMarkers.Count) ? ShowMarkers[i] : false;
                    if (showMarker)
                    {
                        await chart.AddTrace(new Scatter
                        {
                            Name = name,
                            Mode = ModeFlag.Text,
                            Marker = marker,
                            ShowLegend = showLegend,
                            Text = name,
                            TextPosition = TextPositionEnum.TopCenter,
                            X = XValuesInUserUnit,
                            Y = YValuesInUserUnit
                        });
                    }
                    else
                    {
                        await chart.AddTrace(new Scatter
                        {
                            Name = name,
                            Mode = modeFlag,
                            Marker = marker,
                            ShowLegend = showLegend,
                            X = XValuesInUserUnit,
                            Y = YValuesInUserUnit
                        });
                    }
                }
            }

            if (plotVersion != _plotVersion)
            {
                return;
            }

            ManageLayout();
            await chart.Relayout();
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ManageLayout()
    {
        if (Parent != null && layout != null && XAxisTitle != null && YAxisTitle != null && chart != null && XUnit != null && YUnit != null)
        {
            string xAxisTitle = GetAxisTitle(XAxisTitle, XUnit, GetXDrillingSignalReference());
            string yAxisTitle = GetAxisTitle(YAxisTitle, YUnit, GetYDrillingSignalReference());

            layout.Height = PlotHeight;
            layout.Width = PlotWidth;
            layout.Title.Text = PlotTitle;
            //updating the list of XAxis
            for (int i = 0; i < layout.XAxis.Count; ++i)
            {
                layout.XAxis.ElementAt(i).Title.Text = xAxisTitle;
                layout.XAxis.ElementAt(i).AutoRange = Plotly.Blazor.LayoutLib.XAxisLib.AutoRangeEnum.True;
                layout.XAxis.ElementAt(i).RangeMode = Plotly.Blazor.LayoutLib.XAxisLib.RangeModeEnum.Normal;
                if (XAxisReversed)
                    layout.XAxis.ElementAt(i).AutoRange = Plotly.Blazor.LayoutLib.XAxisLib.AutoRangeEnum.Reversed;
            }

            //updating the list of YAxis
            for (int i = 0; i < layout.YAxis.Count; ++i)
            {
                layout.XAxis.ElementAt(i).Title.Text = xAxisTitle;
                layout.YAxis.ElementAt(i).Title.Text = yAxisTitle;
                layout.YAxis.ElementAt(i).AutoRange = Plotly.Blazor.LayoutLib.YAxisLib.AutoRangeEnum.True;
                layout.YAxis.ElementAt(i).RangeMode = Plotly.Blazor.LayoutLib.YAxisLib.RangeModeEnum.Normal;
                if (YAxisReversed)
                    layout.YAxis.ElementAt(i).AutoRange = Plotly.Blazor.LayoutLib.YAxisLib.AutoRangeEnum.Reversed;
                if (AspectRatio != null && AspectRatio > 0)
                {
                    layout.YAxis.ElementAt(i).ScaleAnchor = "x";
                    layout.YAxis.ElementAt(i).ScaleRatio = AspectRatio;
                }
            }
        }
    }
}
